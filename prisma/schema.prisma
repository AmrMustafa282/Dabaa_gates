generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Gate {
  id        String   @id @default(cuid())
  name      String
  ip        String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([order])
}

model HealthLog {
  id        String   @id @default(cuid())
  gateId    String?
  gateName  String
  ip        String?
  type      String
  status    String?
  pingTime  Int?
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([gateId])
  @@index([type])
}
